{
  "title": "Compagnon Immobilier - API Monitoring",
  "uid": "compagnon-immo",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Prédictions totales",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(immo_predictions_total)",
          "legendFormat": "Total prédictions",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Erreurs de prédiction",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(immo_prediction_errors_total)",
          "legendFormat": "Erreurs",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latence médiane (p50)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(immo_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Latence p95",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(immo_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Prédictions par minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(immo_predictions_total[1m]) * 60",
          "legendFormat": "req/min",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Distribution de latence",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(immo_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        },
        {
          "expr": "histogram_quantile(0.95, rate(immo_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        },
        {
          "expr": "histogram_quantile(0.99, rate(immo_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Taux d'erreur (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(immo_prediction_errors_total[5m]) / rate(immo_predictions_total[5m]) * 100",
          "legendFormat": "Taux d'erreur",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "title": "Prédictions par segment",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(immo_predictions_total[5m])",
          "legendFormat": "{{segment}}",
          "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}
